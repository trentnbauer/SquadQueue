{
  "name": "queueup",
  "private": true,
  "workspaces": [
    "packages/shared",
    "server",
    "web"
  ],
  "scripts": {
    "predev": "npm run build -w packages/shared",
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm run dev -w server\" \"npm run dev -w web\"",
    "build": "npm run build -w packages/shared && npm run build -w server && npm run build -w web",
    "db:generate": "npm run db:generate -w server",
    "db:push": "npm run db:push -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:studio": "npm run db:studio -w server",
    "test": "vitest run",
    "changelog:generate": "bash .github/scripts/generate-changelog.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "ajv": {
      "fast-uri": "^3.1.4"
    },
    "fast-json-stringify": {
      "fast-uri": "^4.1.1"
    }
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true,
    "esbuild@0.25.12": true
  }
}
