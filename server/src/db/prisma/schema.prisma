generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameStatus {
  backlog
  playing
  done
  /// "We bounced off this and aren't going back" - distinct from done so it doesn't pollute
  /// completion stats, and excluded from Spin the Wheel same as playing/done.
  dropped
  /// Not yet owned/added for real - tracked so pricing/ATL alerts are useful before a purchase,
  /// not just after. Excluded from Spin the Wheel same as done/dropped (nothing to play yet).
  wishlist

  @@map("game_status")
}

enum RoomRole {
  room_master
  moderator
  member

  @@map("room_role")
}

enum RoomPlatform {
  pc
  xbox_360
  xbox_one
  xbox_series
  ps3
  ps4
  ps5
  switch
  switch2

  @@map("room_platform")
}

enum NotificationType {
  game_added
  member_joined
  room_renamed
  room_platform_changed
  room_owner_changed
  room_deleted
  price_drop

  @@map("notification_type")
}

model User {
  id           String   @id @default(uuid())
  oidcSub      String   @unique @map("oidc_sub")
  /// Set when this user links a Steam account without signing in with it directly (oidcSub is
  /// already taken by their primary sign-in provider) - see the Steam-link flow in auth.ts.
  /// Steam sign-in users don't need this populated; their Steam ID lives in oidcSub instead.
  steamId64    String?  @unique @map("steam_id64")
  email        String
  displayName  String   @map("display_name")
  avatarColor  String   @default("#8f8aa8") @map("avatar_color")
  avatarUrl    String?  @map("avatar_url")
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  /// Systems the user has ticked as "owned" on their Personal Shelf - scopes the add-game
  /// search/create flow there the same way a Room's platform scopes it for a room. Empty means
  /// no opt-in yet, so no filtering is applied (preserves pre-existing behavior).
  ownedPlatforms RoomPlatform[] @default([]) @map("owned_platforms")

  roomsCreated         Room[]          @relation("RoomCreatedBy")
  memberships          RoomMember[]
  gamesAdded           Game[]
  votes                Vote[]
  auditLogEntries      AdminAuditLog[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsActed   Notification[]  @relation("NotificationActor")
  ownedGames           GameOwnership[]
  linkedIdentities     LinkedIdentity[]

  @@map("users")
}

/// A non-primary sign-in method attached to a user, letting them log into one account with more
/// than one OAuth provider (e.g. primary sign-in via Discord, with Google also linked). The
/// original sign-in identity a user signs up with always stays on User.oidcSub; only providers
/// linked afterward go here. Steam is the one exception - linking Steam still writes
/// User.steamId64 instead of a row here (see that field's comment), so the already-tested
/// Steam-library-import path (steamLibrary.ts) didn't need to change to support this.
model LinkedIdentity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  provider  String
  oidcSub   String   @unique @map("oidc_sub")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One linked identity per provider per user - relinking the same provider (e.g. switching which
  // Google account is linked) replaces the row rather than accumulating a second one.
  @@unique([userId, provider])
  @@map("linked_identities")
}

/// A user's ownership claim on a game, keyed by igdbId (not a specific Game row) - this is a fact
/// about the user and the title, not about any one shelf/room listing of it, so a Steam import (or
/// a manual toggle) marking a game owned automatically applies everywhere that igdbId shows up
/// across every room and the Personal Shelf, with nothing to "sync." Steam import writes these
/// automatically; a room member can also toggle one manually for a game they own on another
/// platform (see gameOwnership.ts).
model GameOwnership {
  userId    String   @map("user_id")
  igdbId    Int      @map("igdb_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, igdbId])
  @@map("game_ownership")
}

model Room {
  id          String       @id @default(uuid())
  name        String
  platform    RoomPlatform
  inviteCode  String       @unique @map("invite_code")
  accentColor String       @default("#8b5cf6") @map("accent_color")
  createdBy   String       @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  /// Posts the same events as the in-app room notification feed to this Discord channel webhook,
  /// if set (see notifications.ts). One-way egress only - QueueUp never reads anything back from it.
  discordWebhookUrl String? @map("discord_webhook_url")
  /// Room Settings toggle: when true, Spin the Wheel's candidate pool is restricted to games every
  /// current member owns (see gameOwnership.ts / SpinWheelCard) instead of the full backlog.
  spinOnlyFullyOwned Boolean @default(false) @map("spin_only_fully_owned")

  creator       User           @relation("RoomCreatedBy", fields: [createdBy], references: [id])
  members       RoomMember[]
  games         Game[]
  notifications Notification[]

  @@map("rooms")
}

model RoomMember {
  roomId   String    @map("room_id")
  userId   String    @map("user_id")
  role     RoomRole  @default(member)
  joinedAt DateTime  @default(now()) @map("joined_at")
  /// Cursor for this member's unread count in their room: notifications created after this (or
  /// after joinedAt, if they've never opened the room's notifications) count as unread. Kept on
  /// the membership row rather than a per-notification read-receipt table since a room's
  /// notification feed is shared by every member and "have I seen everything up to here" is all
  /// that's ever asked of it - a receipt per (notification, member) would track the same fact at
  /// far higher cost.
  notificationsReadAt DateTime? @map("notifications_read_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@map("room_members")
}

model Game {
  id             String     @id @default(uuid())
  roomId         String?    @map("room_id")
  addedBy        String     @map("added_by")
  igdbId         Int        @map("igdb_id")
  title          String
  platform       String
  genre          String?
  /// Captured at intake time from IGDB - not re-fetchable later without hitting IGDB again per
  /// game, so this needs to be saved when the game is added, not derived after the fact.
  releaseYear    Int?       @map("release_year")
  maxCoopPlayers Int?       @map("max_coop_players")
  /// Hours for an average "main story" playthrough, from IGDB's game_time_to_beats endpoint
  /// (issue #189) - same capture-at-intake reasoning as releaseYear/maxCoopPlayers above. Null
  /// when IGDB has no time-to-beat data for this game.
  timeToBeatHours Int?      @map("time_to_beat_hours")
  ggDealsUrl     String?    @map("gg_deals_url")
  steamAppid     Int?       @map("steam_appid")
  coverImageUrl  String?    @map("cover_image_url")
  status         GameStatus @default(backlog)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  /// Set by the admin bulk-archive action (Done games untouched for 90+ days) - archived games are
  /// hidden from normal shelf/room listings but not deleted, preserving history.
  archivedAt     DateTime?  @map("archived_at")
  /// A price to alert at, set by any user who can see the game (string decimal, matching the
  /// existing price-string convention - see GamePrice). Shared per-game rather than per-user: a
  /// room game has one target that notifies the whole room, same as any other room notification.
  /// Cleared automatically once the alert fires (see priceAlerts.ts) so a price that stays low
  /// doesn't re-notify on every subsequent page load.
  targetPrice    String?    @map("target_price")
  /// The live price we last sent an all-time-low alert for (see priceAlerts.ts) - lets us notify
  /// again if the price drops even further, without re-notifying on every subsequent check while
  /// it sits at the same low. Independent of targetPrice, which is a user-set threshold.
  notifiedAtlPrice String?  @map("notified_atl_price")

  room  Room?  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  adder User   @relation(fields: [addedBy], references: [id], onDelete: Cascade)
  votes Vote[]

  @@index([roomId])
  @@index([addedBy], map: "idx_games_personal")
  @@index([roomId, igdbId])
  @@index([addedBy, igdbId])
  @@map("games")
}

model Vote {
  gameId    String   @map("game_id")
  userId    String   @map("user_id")
  // 1-5, validated at the API layer AND by a DB-level CHECK constraint (votes_value_range) -
  // Prisma's schema DSL has no CHECK support, so that constraint is applied at boot instead,
  // see db/ensureConstraints.ts.
  value     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([gameId, userId])
  @@map("votes")
}

/// Room-activity feed entry: game added, member joined, room renamed/platform/owner changed, or a
/// room deletion notice. Room-scoped entries (roomId set) are shared by every current member and
/// read state is tracked via RoomMember.notificationsReadAt rather than per-row, since the same
/// row is "the same notification" for everyone in the room. Direct entries (recipientId set, roomId
/// null) exist only for events with no room left to attach to - namely a room being deleted, where
/// each former member gets their own row (with readAt tracked right here, since it's addressed to
/// exactly one person) so the notice survives the room it's about.
/// roomName is a snapshot taken at creation time rather than a live join through roomId, since a
/// direct notification about a deleted room has no room row left to join through.
model Notification {
  id          String           @id @default(uuid())
  roomId      String?          @map("room_id")
  roomName    String           @map("room_name")
  recipientId String?          @map("recipient_id")
  actorId     String?          @map("actor_id")
  type        NotificationType
  message     String
  createdAt   DateTime         @default(now()) @map("created_at")
  /// Only meaningful for direct (recipientId set) rows - see the model doc above.
  readAt      DateTime?        @map("read_at")

  room      Room? @relation(fields: [roomId], references: [id], onDelete: Cascade)
  recipient User? @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt])
  @@index([recipientId, createdAt])
  @@map("notifications")
}

/// Durable record of destructive admin actions (user/room delete, bulk-archive) - a structured
/// log line alone doesn't survive log rotation or a container restart, so this is the actual
/// source of truth for "who did what, when." actorId is nullable with onDelete: SetNull rather
/// than Cascade so a log entry outlives the admin account that made it - actorLabel/targetLabel
/// are snapshots taken at write time so the entry stays meaningful even after that.
model AdminAuditLog {
  id          String   @id @default(uuid())
  actorId     String?  @map("actor_id")
  actorLabel  String   @map("actor_label")
  action      String
  targetLabel String?  @map("target_label")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("admin_audit_log")
}

/// Small key-value fallback store for admin-configurable integration credentials (gg.deals API
/// key, IGDB client id/secret) that weren't set via env var - see
/// server/src/services/configResolver.ts, which always prefers the env var and only reads this
/// table to fill the gap when it's unset. Values are plain text: these are already admin-only
/// credentials shown (masked) to admins in the Settings UI. If this table ever grows to hold more
/// sensitive secrets, add encryption at rest before relying on it further - not done now to avoid
/// over-engineering a handful of low-sensitivity API keys.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("app_settings")
}
