generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameStatus {
  backlog
  playing
  done
  /// "We bounced off this and aren't going back" - distinct from done so it doesn't pollute
  /// completion stats, and excluded from Spin the Wheel same as playing/done.
  dropped
  /// Not yet owned/added for real - tracked so pricing/ATL alerts are useful before a purchase,
  /// not just after. Excluded from Spin the Wheel same as done/dropped (nothing to play yet).
  wishlist
  /// Beaten before, and queued to play again - included in Spin the Wheel's candidate pool same
  /// as backlog (that's the whole point of flagging it), but kept distinct from backlog so it can
  /// be labeled/filtered separately rather than looking like it was never played.
  replay

  @@map("game_status")
}

enum RoomRole {
  room_master
  moderator
  member

  @@map("room_role")
}

enum RoomPlatform {
  pc
  xbox_360
  xbox_one
  xbox_series
  ps3
  ps4
  ps5
  switch
  switch2

  @@map("room_platform")
}

/// Which visual presentation Spin the Wheel uses (issue #297) - room master only to change, same
/// gating as Room.spinOnlyFullyOwned. "random" isn't itself a renderable theme - it resolves to
/// one of the other four at spin time (see resolveConcreteTheme in the web app), re-rolled fresh
/// on every spin rather than fixed once per room.
enum SpinWheelTheme {
  slot
  crate
  card_flip
  roulette
  random

  @@map("spin_wheel_theme")
}

enum NotificationType {
  game_added
  member_joined
  room_renamed
  room_platform_changed
  room_owner_changed
  room_deleted
  price_drop

  @@map("notification_type")
}

model User {
  id           String   @id @default(uuid())
  oidcSub      String   @unique @map("oidc_sub")
  /// Set when this user links a Steam account without signing in with it directly (oidcSub is
  /// already taken by their primary sign-in provider) - see the Steam-link flow in auth.ts.
  /// Steam sign-in users don't need this populated; their Steam ID lives in oidcSub instead.
  steamId64    String?  @unique @map("steam_id64")
  email        String
  displayName  String   @map("display_name")
  avatarColor  String   @default("#8f8aa8") @map("avatar_color")
  avatarUrl    String?  @map("avatar_url")
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  /// Systems the user has ticked as "owned" on their Personal Shelf - scopes the add-game
  /// search/create flow there the same way a Room's platform scopes it for a room. Empty means
  /// no opt-in yet, so no filtering is applied (preserves pre-existing behavior).
  ownedPlatforms RoomPlatform[] @default([]) @map("owned_platforms")

  roomsCreated         Room[]          @relation("RoomCreatedBy")
  memberships          RoomMember[]
  gamesAdded           Game[]
  votes                Vote[]
  auditLogEntries      AdminAuditLog[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsActed   Notification[]  @relation("NotificationActor")
  ownedGames           GameOwnership[]
  achievementCompletions AchievementCompletion[]
  linkedIdentities     LinkedIdentity[]
  tags                 Tag[]

  @@map("users")
}

/// A non-primary sign-in method attached to a user, letting them log into one account with more
/// than one OAuth provider (e.g. primary sign-in via Discord, with Google also linked). The
/// original sign-in identity a user signs up with always stays on User.oidcSub; only providers
/// linked afterward go here. Steam is the one exception - linking Steam still writes
/// User.steamId64 instead of a row here (see that field's comment), so the already-tested
/// Steam-library-import path (steamLibrary.ts) didn't need to change to support this.
model LinkedIdentity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  provider  String
  oidcSub   String   @unique @map("oidc_sub")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One linked identity per provider per user - relinking the same provider (e.g. switching which
  // Google account is linked) replaces the row rather than accumulating a second one.
  @@unique([userId, provider])
  @@map("linked_identities")
}

/// A user's ownership claim on a game, keyed by igdbId (not a specific Game row) - this is a fact
/// about the user and the title, not about any one shelf/room listing of it, so a Steam import (or
/// a manual toggle) marking a game owned automatically applies everywhere that igdbId shows up
/// across every room and the Personal Shelf, with nothing to "sync." Steam import writes these
/// automatically; a room member can also toggle one manually for a game they own on another
/// platform (see gameOwnership.ts).
model GameOwnership {
  userId    String   @map("user_id")
  igdbId    Int      @map("igdb_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, igdbId])
  @@map("game_ownership")
}

/// A per-user, per-title fact that this user's Steam achievement progress has hit 100% at least
/// once, keyed by igdbId (not gameId) like GameOwnership - so it transfers across re-adds and
/// between rooms/shelf the same way ownership does, rather than being tied to one Game row. Sticky
/// by construction: rows are only ever inserted, never deleted or "un-completed", since a 100% run
/// stays true forever regardless of later achievement resets. Populated opportunistically wherever
/// achievement progress is already being checked (the achievements route, and Steam completion
/// auto-detection) - never a fresh Steam API call of its own. Powers the per-member "completed /
/// 100%'d" counts shown in a room's member list.
model AchievementCompletion {
  userId    String   @map("user_id")
  igdbId    Int      @map("igdb_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, igdbId])
  @@map("achievement_completion")
}

model Room {
  id          String       @id @default(uuid())
  name        String
  platform    RoomPlatform
  inviteCode  String       @unique @map("invite_code")
  accentColor String       @default("#8b5cf6") @map("accent_color")
  createdBy   String       @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  /// Posts the same events as the in-app room notification feed to this Discord channel webhook,
  /// if set (see notifications.ts). One-way egress only - QueueUp never reads anything back from it.
  discordWebhookUrl String? @map("discord_webhook_url")
  /// Room Settings toggle: when true, Spin the Wheel's candidate pool is restricted to games every
  /// current member owns (see gameOwnership.ts / SpinWheelCard) instead of the full backlog.
  spinOnlyFullyOwned Boolean @default(false) @map("spin_only_fully_owned")
  /// Which visual presentation Spin the Wheel uses (issue #297) - defaults to the original
  /// slot-machine reel so existing rooms don't change.
  spinWheelTheme SpinWheelTheme @default(slot) @map("spin_wheel_theme")

  creator       User           @relation("RoomCreatedBy", fields: [createdBy], references: [id])
  members       RoomMember[]
  games         Game[]
  notifications Notification[]

  @@map("rooms")
}

model RoomMember {
  roomId   String    @map("room_id")
  userId   String    @map("user_id")
  role     RoomRole  @default(member)
  joinedAt DateTime  @default(now()) @map("joined_at")
  /// Cursor for this member's unread count in their room: notifications created after this (or
  /// after joinedAt, if they've never opened the room's notifications) count as unread. Kept on
  /// the membership row rather than a per-notification read-receipt table since a room's
  /// notification feed is shared by every member and "have I seen everything up to here" is all
  /// that's ever asked of it - a receipt per (notification, member) would track the same fact at
  /// far higher cost.
  notificationsReadAt DateTime? @map("notifications_read_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@map("room_members")
}

model Game {
  id             String     @id @default(uuid())
  roomId         String?    @map("room_id")
  addedBy        String     @map("added_by")
  igdbId         Int        @map("igdb_id")
  title          String
  platform       String
  genre          String?
  /// Captured at intake time from IGDB - not re-fetchable later without hitting IGDB again per
  /// game, so this needs to be saved when the game is added, not derived after the fact.
  releaseYear    Int?       @map("release_year")
  /// Full release date/time (issue #284) - releaseYear alone is only precise to the year, which
  /// isn't enough to reliably tell "already released" from "releasing later this year" for Spin
  /// the Wheel's isUnreleased check. Null on games added before this field existed; that check
  /// falls back to the year-only heuristic for those rather than requiring a backfill.
  releaseDate    DateTime?  @map("release_date")
  /// IGDB's franchise/series id for this game, if it belongs to one (issue #283) - captured at
  /// intake same as releaseYear/maxCoopPlayers above. Not surfaced anywhere yet; laying the
  /// groundwork for a future "recommend playing the prior entry first" Spin the Wheel feature
  /// without needing a second IGDB round trip per game once that's built. Null on games added
  /// before this field existed, and on any game IGDB doesn't have in a collection.
  igdbCollectionId Int?     @map("igdb_collection_id")
  maxCoopPlayers Int?       @map("max_coop_players")
  /// Hours for an average "main story" playthrough, from IGDB's game_time_to_beats endpoint
  /// (issue #189) - same capture-at-intake reasoning as releaseYear/maxCoopPlayers above. Null
  /// when IGDB has no time-to-beat data for this game. Sourced from IGDB's "normally" figure -
  /// kept as-is (issue #248) so this column's meaning doesn't shift out from under rows already
  /// on file; see timeToBeatRushedHours/timeToBeatCompletionistHours for the rest of the
  /// breakdown IGDB exposes alongside it.
  timeToBeatHours Int?      @map("time_to_beat_hours")
  /// Hours for a rushed/speedrun-style playthrough, from IGDB's game_time_to_beats "hastily"
  /// figure (issue #248) - same capture-at-intake reasoning as timeToBeatHours above. Null when
  /// IGDB has no time-to-beat data for this game. This is always less time than timeToBeatHours
  /// (Main Story), not more - the three game_time_to_beats figures are strictly ordered hastily <
  /// normally < completely - so it's additive alongside timeToBeatHours rather than replacing it,
  /// but represents a quicker/less-thorough clear, not a fuller one.
  timeToBeatRushedHours        Int? @map("time_to_beat_rushed_hours")
  /// Hours for a full completionist (100%) playthrough, from IGDB's game_time_to_beats
  /// "completely" figure (issue #248) - same capture-at-intake reasoning as timeToBeatHours
  /// above. Null when IGDB has no time-to-beat data for this game.
  timeToBeatCompletionistHours Int? @map("time_to_beat_completionist_hours")
  /// 0-100 review score (issue #311) - IGDB's total_rating (blended critic+user), falling back to
  /// aggregated_rating (critic-only) then rating (user-only) if the preferred figure is missing -
  /// see reviewScoreFrom in igdbClient.ts. Same capture-at-intake reasoning as maxCoopPlayers
  /// above. Null when IGDB has no review data at all for this game (not a penalty - Spin the
  /// Wheel's weighting treats it the same as a game nobody's voted on), or on games added before
  /// this field existed.
  reviewScore    Int?       @map("review_score")
  ggDealsUrl     String?    @map("gg_deals_url")
  steamAppid     Int?       @map("steam_appid")
  coverImageUrl  String?    @map("cover_image_url")
  status         GameStatus @default(backlog)
  /// Set the first time any player's Steam achievement progress on this game is observed at
  /// 100% (opening the detail modal, "Sync completions from Steam", or Year in Review) - never
  /// computed live on every grid render, which would mean a Steam API call per Steam-linked game
  /// per page view. Drives the card ribbon showing "Clocked" (gold) instead of "Beaten" (green)
  /// for a Done game. Sticky once true - a later Replay doesn't clear it, since it's a record of
  /// "this has been 100%'d before," not "the current playthrough is 100%'d."
  steamFullyCompleted Boolean @default(false) @map("steam_fully_completed")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  /// Set by the admin bulk-archive action (Done games untouched for 90+ days) - archived games are
  /// hidden from normal shelf/room listings but not deleted, preserving history.
  archivedAt     DateTime?  @map("archived_at")
  /// A price to alert at, set by any user who can see the game (string decimal, matching the
  /// existing price-string convention - see GamePrice). Shared per-game rather than per-user: a
  /// room game has one target that notifies the whole room, same as any other room notification.
  /// Cleared automatically once the alert fires (see priceAlerts.ts) so a price that stays low
  /// doesn't re-notify on every subsequent page load.
  targetPrice    String?    @map("target_price")
  /// The live price we last sent an all-time-low alert for (see priceAlerts.ts) - lets us notify
  /// again if the price drops even further, without re-notifying on every subsequent check while
  /// it sits at the same low. Independent of targetPrice, which is a user-set threshold.
  notifiedAtlPrice String?  @map("notified_atl_price")
  /// User-set "play this after" pointer to another game in the same room (issue: play-after
  /// dropdown) - e.g. Borderlands 2 pointed at Borderlands 1. Purely organizational: nothing
  /// enforces it at write time beyond same-room + not-self (checked at the API layer, not here),
  /// but Spin the Wheel's candidate pool excludes a game with an unmet prerequisite (its target
  /// not yet marked Done) - see hasUnmetPrerequisite in gameGridLogic.ts. SetNull on delete rather
  /// than blocking the delete: removing the prerequisite game should un-stick its successor, not
  /// prevent the removal.
  prerequisiteGameId String? @map("prerequisite_game_id")

  room  Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  adder User      @relation(fields: [addedBy], references: [id], onDelete: Cascade)
  votes Vote[]
  tags  GameTag[]
  prerequisiteGame Game?  @relation("GamePrerequisite", fields: [prerequisiteGameId], references: [id], onDelete: SetNull)
  successorGames   Game[] @relation("GamePrerequisite")

  @@index([roomId])
  @@index([addedBy], map: "idx_games_personal")
  @@index([roomId, igdbId])
  @@index([addedBy, igdbId])
  @@index([prerequisiteGameId])
  @@map("games")
}

model Vote {
  gameId    String   @map("game_id")
  userId    String   @map("user_id")
  // 1-5, validated at the API layer AND by a DB-level CHECK constraint (votes_value_range) -
  // Prisma's schema DSL has no CHECK support, so that constraint is applied at boot instead,
  // see db/ensureConstraints.ts.
  value     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([gameId, userId])
  @@map("votes")
}

/// A user-defined organizational label (issue #247), layered on top of the fixed GameStatus enum -
/// e.g. "Co-op only" or "Short & sweet". Deliberately per-user rather than global/shared: a tag you
/// create applies across your own Personal Shelf items and any room games you added (see GameTag's
/// access rule in gameAccess.ts), the same way GameOwnership and the Personal Shelf itself are
/// scoped to a user rather than a room. Not visible to (or editable by) other room members, even on
/// a shared room game - this is a personal filing scheme, not a room feature (out of scope per the
/// issue). Schema-only change, additive and `db push`-safe like the rest of this file (no migration
/// history is kept - see server/src/db/ensureConstraints.ts's comment for why).
model Tag {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  games GameTag[]

  // A user can't create two tags with the same name - the create/rename routes rely on this
  // constraint (via a caught P2002, same pattern as the room invite-code/LinkedIdentity routes)
  // rather than a separate SELECT-then-INSERT existence check.
  @@unique([userId, name])
  @@map("tags")
}

/// Join row for the per-user Tag <-> Game many-to-many (issue #247). Keyed on the specific Game row
/// (not igdbId, unlike GameOwnership) - a tag is an organizational label on one shelf/room listing,
/// not a fact about the title itself, so tagging one copy of a game says nothing about another
/// listing of the same title elsewhere (e.g. the same game on your shelf AND in a room). Cascades in
/// both directions: deleting a Game drops its tag associations, and deleting a Tag drops it from
/// every game it was on - there's no "can't delete, still in use" guard (see the tag-delete route
/// for that reasoning).
model GameTag {
  gameId    String   @map("game_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gameId, tagId])
  @@index([tagId])
  @@map("game_tags")
}

/// Room-activity feed entry: game added, member joined, room renamed/platform/owner changed, or a
/// room deletion notice. Room-scoped entries (roomId set) are shared by every current member and
/// read state is tracked via RoomMember.notificationsReadAt rather than per-row, since the same
/// row is "the same notification" for everyone in the room. Direct entries (recipientId set, roomId
/// null) exist only for events with no room left to attach to - namely a room being deleted, where
/// each former member gets their own row (with readAt tracked right here, since it's addressed to
/// exactly one person) so the notice survives the room it's about.
/// roomName is a snapshot taken at creation time rather than a live join through roomId, since a
/// direct notification about a deleted room has no room row left to join through.
model Notification {
  id          String           @id @default(uuid())
  roomId      String?          @map("room_id")
  roomName    String           @map("room_name")
  recipientId String?          @map("recipient_id")
  actorId     String?          @map("actor_id")
  type        NotificationType
  message     String
  createdAt   DateTime         @default(now()) @map("created_at")
  /// Only meaningful for direct (recipientId set) rows - see the model doc above.
  readAt      DateTime?        @map("read_at")

  room      Room? @relation(fields: [roomId], references: [id], onDelete: Cascade)
  recipient User? @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt])
  @@index([recipientId, createdAt])
  @@map("notifications")
}

/// Durable record of destructive admin actions (user/room delete, bulk-archive) - a structured
/// log line alone doesn't survive log rotation or a container restart, so this is the actual
/// source of truth for "who did what, when." actorId is nullable with onDelete: SetNull rather
/// than Cascade so a log entry outlives the admin account that made it - actorLabel/targetLabel
/// are snapshots taken at write time so the entry stays meaningful even after that.
model AdminAuditLog {
  id          String   @id @default(uuid())
  actorId     String?  @map("actor_id")
  actorLabel  String   @map("actor_label")
  action      String
  targetLabel String?  @map("target_label")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("admin_audit_log")
}

/// Small key-value fallback store for admin-configurable integration credentials (gg.deals API
/// key, IGDB client id/secret) that weren't set via env var - see
/// server/src/services/configResolver.ts, which always prefers the env var and only reads this
/// table to fill the gap when it's unset. Values are plain text: these are already admin-only
/// credentials shown (masked) to admins in the Settings UI. If this table ever grows to hold more
/// sensitive secrets, add encryption at rest before relying on it further - not done now to avoid
/// over-engineering a handful of low-sensitivity API keys.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("app_settings")
}
