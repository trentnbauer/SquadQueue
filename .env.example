# Copy to .env and fill in. .env is gitignored.

# --- Postgres ---
POSTGRES_USER=squadqueue
POSTGRES_PASSWORD=changeme
POSTGRES_DB=squadqueue
DATABASE_URL=postgresql://squadqueue:changeme@localhost:5432/squadqueue

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=3000
APP_BASE_URL=http://localhost:5173
SESSION_SECRET=change-this-to-a-long-random-string

# --- OIDC (register SquadQueue as a client with your provider, e.g. Authelia/Keycloak/Authentik/Google) ---
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_SCOPES=openid profile email

# Set to true to skip OIDC entirely and log every request in as a hardcoded dev user.
# NEVER enable in production. Useful before you've set up an OIDC provider.
DEV_FAKE_AUTH=false

# Comma-separated emails granted administrator access (settings menu, delete rooms/users)
# on login. Re-checked every login, so you can add/remove admins by editing this and having
# them sign in again. Ignored (everyone is admin) when DEV_FAKE_AUTH=true.
ADMIN_EMAILS=

# --- gg.deals (https://gg.deals/api/ - free API key from your account settings) ---
# Used for live Steam pricing only (game search/identity now comes from IGDB below).
GGDEALS_API_KEY=
GGDEALS_DEFAULT_REGION=us

# --- IGDB (game search, cover art, platforms, Steam App ID lookup) ---
# Free: register a Twitch developer app at https://dev.twitch.tv/console/apps
# (Category: "Application Integration"), then copy its Client ID and generate a Client Secret.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- Backups ---
# Root directory bind-mounted for Postgres/Redis persistence (point Borg or similar here).
DATA_DIR=./data
