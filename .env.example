# Copy to .env and fill in. .env is gitignored.

# --- Postgres ---
POSTGRES_USER=squadqueue
POSTGRES_PASSWORD=changeme
POSTGRES_DB=squadqueue
DATABASE_URL=postgresql://squadqueue:changeme@localhost:5432/squadqueue

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=3000
APP_BASE_URL=http://localhost:5173
SESSION_SECRET=change-this-to-a-long-random-string

# Trust the reverse proxy in front of this container (Cloudflare Tunnel, NGINX Proxy Manager,
# Traefik, ...) so request IP/protocol are read from X-Forwarded-For/X-Forwarded-Proto instead
# of the raw (typically plain-HTTP-inside-Docker) connection. This is what lets session cookies
# get marked Secure once TLS is confirmed at the proxy, and keeps per-user rate limiting working
# (otherwise every visitor looks like the proxy's single IP). Defaults to true - almost everyone
# running this runs it behind something. Set to false only if this container is reachable
# directly with nothing in front of it. Advanced: a number (trusted hop count) or an IP/CIDR
# (or comma-separated list) also works, for locking this down to a known proxy address.
TRUST_PROXY=true

# --- Sign-in methods. Configure one or more; the login screen shows a button per one that's
# --- fully filled in. All are optional, but you need at least one unless DEV_FAKE_AUTH=true.
#
# Each *_REDIRECT_URI below defaults to `${APP_BASE_URL}/auth/<provider>/callback` when left
# blank, which is correct for the documented production setup (docker-compose.prod.yml runs one
# server container serving both the API and the frontend, so that's genuinely where the callback
# lands) - leave them blank there. The values below are filled in because `npm run dev` splits the
# frontend (Vite, :5173) and backend (:3000) across two ports/origins, so APP_BASE_URL alone isn't
# enough to find the callback in dev; set your own here only if your setup needs something else.

# Generic OIDC (any standards-compliant provider - Authelia, Keycloak, Authentik, etc).
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/oidc/callback
OIDC_SCOPES=openid profile email

# Google (console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Discord (discord.com/developers/applications -> New Application -> OAuth2).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Steam (steamcommunity.com/dev/apikey for the API key - Steam itself needs no client id/secret,
# it uses a different, older login protocol). Steam accounts have no email address; users signing
# in with Steam get a placeholder email under the hood.
STEAM_API_KEY=
STEAM_REDIRECT_URI=http://localhost:3000/auth/steam/callback

# Set to true to skip real sign-in entirely and log every request in as a hardcoded dev user.
# NEVER enable in production. Useful before you've set up any of the above.
DEV_FAKE_AUTH=false

# Comma-separated emails granted administrator access (settings menu, delete rooms/users)
# on login. Re-checked every login, so you can add/remove admins by editing this and having
# them sign in again. Ignored (everyone is admin) when DEV_FAKE_AUTH=true.
ADMIN_EMAILS=

# --- gg.deals (https://gg.deals/api/ - free API key from your account settings) ---
# Used for live Steam pricing only (game search/identity now comes from IGDB below).
# Optional here: if left blank, an admin can instead set it as a DB-stored fallback from the
# Settings panel in the app (Integrations section) - an env var here always takes precedence
# over that DB value if both are set.
GGDEALS_API_KEY=
GGDEALS_DEFAULT_REGION=us

# --- IGDB (game search, cover art, platforms, Steam App ID lookup) ---
# Free: register a Twitch developer app at https://dev.twitch.tv/console/apps
# (Category: "Application Integration"), then copy its Client ID and generate a Client Secret.
# Optional here too, same DB-fallback mechanism as gg.deals above.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- Backups ---
# Root directory bind-mounted for Postgres/Redis persistence (point Borg or similar here).
DATA_DIR=./data

# docker-compose.prod.yml's `backup` service runs a scheduled `pg_dump` on this cadence, gzipped
# to ${DATA_DIR}/backups, keeping only the newest BACKUP_RETENTION_COUNT dumps. See the README's
# "Backups" section for the restore procedure. Not used by docker-compose.yml (local dev).
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_COUNT=14
